# ============================================
# LearnOpenCV_Test жөӢиҜ•жЁЎеқ—й…ҚзҪ®
# ============================================

# жөӢиҜ•еҸҜжү§иЎҢж–Үд»¶еҗҚз§°
TEST_EXECUTABLE := LearnOpenCV_Test

# жөӢиҜ•жәҗж–Үд»¶зӣ®еҪ•
TEST_SRC_DIR := tests

# иҺ·еҸ–жүҖжңүжөӢиҜ•ж–Үд»¶пјҲжҺ’йҷӨ main.cc е’Ң pch.ccпјү
TEST_SOURCES := $(wildcard $(TEST_SRC_DIR)/*.cc) $(wildcard $(TEST_SRC_DIR)/*.cpp)
TEST_FILE_NAMES := $(basename $(notdir $(TEST_SOURCES)))
TEST_FILE_NAMES := $(filter-out main pch, $(TEST_FILE_NAMES))

# ============================================
# жһ„е»әи·Ҝеҫ„й…ҚзҪ®
# ============================================

# жЈҖжөӢе®һйҷ…еӯҳеңЁзҡ„жһ„е»әзӣ®еҪ•
ifneq ($(wildcard build-Debug),)
    BUILD_DIR_DEBUG_ACTUAL := build-Debug
else
    BUILD_DIR_DEBUG_ACTUAL := build-debug
endif

ifneq ($(wildcard build-Release),)
    BUILD_DIR_RELEASE_ACTUAL := build-Release
else
    BUILD_DIR_RELEASE_ACTUAL := build-release
endif

# жҹҘжүҫжөӢиҜ•еҸҜжү§иЎҢж–Үд»¶
define find_test_exec
$(firstword $(wildcard $(1)/bin/$(TEST_EXECUTABLE)) $(wildcard $(1)/$(TEST_EXECUTABLE)))
endef

TEST_EXEC_DEBUG := $(call find_test_exec,$(BUILD_DIR_DEBUG_ACTUAL))
TEST_EXEC_RELEASE := $(call find_test_exec,$(BUILD_DIR_RELEASE_ACTUAL))

# ============================================
# иҫ…еҠ©еҮҪж•°
# ============================================

# д»ҺжөӢиҜ•ж–Үд»¶дёӯжҸҗеҸ–жүҖжңүжөӢиҜ•з”ЁдҫӢеҗҚз§°
define get_test_cases_from_file
$(shell grep -oP 'TEST_F\(\s*\w+\s*,\s*\K[^)]+' $(TEST_SRC_DIR)/$(1).cc 2>/dev/null)
endef

# ============================================
# жһ„е»әжЈҖжҹҘ
# ============================================

build-debug-check:
	@if [ ! -f "$(TEST_EXEC_DEBUG)" ]; then \
		echo "Debug executable not found, building..."; \
		$(MAKE) debug; \
	fi

build-release-check:
	@if [ ! -f "$(TEST_EXEC_RELEASE)" ]; then \
		echo "Release executable not found, building..."; \
		$(MAKE) release; \
	fi

# ============================================
# иҝҗиЎҢжөӢиҜ•ж–Үд»¶дёӯзҡ„жүҖжңүжөӢиҜ•пјҲдҝ®жӯЈзүҲпјү
# ============================================

define run-test-file-all
.PHONY: $(1)
$(1): build-debug-check
	@echo "========================================"
	@echo "Running all tests in $(1).cc"
	@echo "========================================"
	@test_cases="$(call get_test_cases_from_file,$(1))"; \
	if [ -z "$$test_cases" ]; then \
		echo "Warning: No test cases found in $(1).cc"; \
		echo "Available tests in this file:"; \
		grep -n 'TEST_F' $(TEST_SRC_DIR)/$(1).cc 2>/dev/null || echo "  (none)"; \
		exit 1; \
	else \
		echo "Found test case(s):"; \
		for test_case in $$test_cases; do \
			echo "  - $$test_case"; \
		done; \
		echo ""; \
		count=0; \
		passed=0; \
		failed=0; \
		for test_case in $$test_cases; do \
			count=`expr $$count + 1`; \
			echo "========================================"; \
			echo "[$$count/`echo $$test_cases | wc -w`] Running: $$test_case"; \
			echo "========================================"; \
			if [ -f "$(TEST_EXEC_DEBUG)" ]; then \
				if $(TEST_EXEC_DEBUG) --gtest_filter="*$$test_case*"; then \
					passed=`expr $$passed + 1`; \
				else \
					failed=`expr $$failed + 1`; \
				fi; \
			else \
				echo "Error: Test executable not found"; \
				exit 1; \
			fi; \
			echo ""; \
		done; \
		echo "========================================"; \
		echo "Summary for $(1).cc"; \
		echo "========================================"; \
		echo "Total: $$count, Passed: $$passed, Failed: $$failed"; \
		if [ $$failed -ne 0 ]; then \
			exit 1; \
		fi; \
	fi
endef

# дёәжҜҸдёӘжөӢиҜ•ж–Үд»¶з”ҹжҲҗиҝҗиЎҢи§„еҲҷ
$(foreach test_file,$(TEST_FILE_NAMES),\
	$(eval $(call run-test-file-all,$(test_file)))\
)

# ============================================
# иҝҗиЎҢжҢҮе®ҡзҡ„жөӢиҜ•з”ЁдҫӢпјҲж”ҜжҢҒзӮ№еҸ·иҜӯжі•пјү
# ============================================

define run-test-case
.PHONY: $(1).$(2)
$(1).$(2): build-debug-check
	@echo "Running test case: $(1).$(2)..."
	@echo "========================================"
	@if [ -f "$(TEST_EXEC_DEBUG)" ]; then \
		$(TEST_EXEC_DEBUG) --gtest_filter="*$(2)*"; \
	elif [ -f "$(TEST_EXEC_RELEASE)" ]; then \
		$(TEST_EXEC_RELEASE) --gtest_filter="*$(2)*"; \
	else \
		echo "Error: $(TEST_EXECUTABLE) not found"; \
		exit 1; \
	fi
endef

# жүӢеҠЁе®ҡд№үе·ІзҹҘзҡ„жөӢиҜ•з”ЁдҫӢ
# CH1_basic_operation ж–Үд»¶дёӯзҡ„жөӢиҜ•з”ЁдҫӢ
$(eval $(call run-test-case,CH1_basic_operation,NamedWindowTest))
$(eval $(call run-test-case,CH1_basic_operation,ReadWriteTest))
$(eval $(call run-test-case,CH1_basic_operation,OpenVideo))

# ============================================
# йҖҡз”ЁжөӢиҜ•иҝҗиЎҢ
# ============================================

# иҝҗиЎҢжүҖжңүжөӢиҜ•
test-all: build-debug-check
	@echo "Running all tests..."
	@if [ -f "$(TEST_EXEC_DEBUG)" ]; then \
		$(TEST_EXEC_DEBUG); \
	elif [ -f "$(TEST_EXEC_RELEASE)" ]; then \
		$(TEST_EXEC_RELEASE); \
	else \
		echo "Error: $(TEST_EXECUTABLE) not found"; \
		exit 1; \
	fi

# иҝҗиЎҢеҢ№й…ҚжЁЎејҸзҡ„жөӢиҜ•
test-pattern-%: build-debug-check
	@pattern="$*"; \
	echo "Running tests matching pattern: $$pattern"; \
	if [ -f "$(TEST_EXEC_DEBUG)" ]; then \
		$(TEST_EXEC_DEBUG) --gtest_filter="*$$pattern*"; \
	elif [ -f "$(TEST_EXEC_RELEASE)" ]; then \
		$(TEST_EXEC_RELEASE) --gtest_filter="*$$pattern*"; \
	else \
		echo "Error: $(TEST_EXECUTABLE) not found"; \
		exit 1; \
	fi

# ============================================
# иҫ…еҠ©еҠҹиғҪ
# ============================================

show-test-config:
	@echo "=== Test Configuration ==="
	@echo "TEST_EXECUTABLE: $(TEST_EXECUTABLE)"
	@echo "TEST_SRC_DIR: $(TEST_SRC_DIR)"
	@echo "TEST_FILE_NAMES: $(TEST_FILE_NAMES)"
	@echo ""
	@echo "=== Build Directories ==="
	@echo "BUILD_DIR_DEBUG_ACTUAL: $(BUILD_DIR_DEBUG_ACTUAL)"
	@echo "BUILD_DIR_RELEASE_ACTUAL: $(BUILD_DIR_RELEASE_ACTUAL)"
	@echo "TEST_EXEC_DEBUG: $(TEST_EXEC_DEBUG)"
	@echo "TEST_EXEC_RELEASE: $(TEST_EXEC_RELEASE)"

list-test-files:
	@echo "Available test files:"
	@$(foreach file,$(TEST_FILE_NAMES),echo "  - $(file)";)
	@echo ""
	@echo "Usage examples:"
	@echo "  make CH1_basic_operation                    # Run all tests in CH1_basic_operation.cc"
	@echo "  make CH1_basic_operation.NamedWindowTest    # Run specific test case"
	@echo "  make test-pattern-NamedWindow               # Run tests matching pattern"
	@echo "  make test-all                               # Run all tests"

list-test-cases-in-%: build-debug-check
	@test_file="$*"; \
	echo "Test cases in $$test_file.cc:"; \
	grep -oP 'TEST_F\(\s*\w+\s*,\s*\K[^)]+' $(TEST_SRC_DIR)/$$test_file.cc 2>/dev/null || \
	grep -oP 'TEST\(\s*\w+\s*,\s*\K[^)]+' $(TEST_SRC_DIR)/$$test_file.cc 2>/dev/null || \
	echo "  (none found)"

list-all-tests: build-debug-check
	@if [ -f "$(TEST_EXEC_DEBUG)" ]; then \
		echo "All test cases in $(TEST_EXECUTABLE):"; \
		echo "========================================"; \
		$(TEST_EXEC_DEBUG) --gtest_list_tests; \
	elif [ -f "$(TEST_EXEC_RELEASE)" ]; then \
		echo "All test cases in $(TEST_EXECUTABLE):"; \
		echo "========================================"; \
		$(TEST_EXEC_RELEASE) --gtest_list_tests; \
	else \
		echo "Error: $(TEST_EXECUTABLE) not found"; \
		exit 1; \
	fi
